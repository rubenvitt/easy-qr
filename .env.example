# OIDC (Pocket ID)
POCKET_ID_ISSUER=https://id.example.org
POCKET_ID_CLIENT_ID=replace-me
POCKET_ID_CLIENT_SECRET=replace-me
POCKET_ID_REDIRECT_URI=http://localhost:3000/auth/callback

# OIDC group -> role mapping (comma-separated, optional).
# Defaults: drk-qr-admin / drk-qr-user. Admin wins if a user is in both lists.
OIDC_ADMIN_GROUPS=drk-qr-admin
OIDC_USER_GROUPS=drk-qr-user

# 32-byte hex (generate: openssl rand -hex 32)
SESSION_SECRET=replace-with-32-bytes-hex

# Public origin of the app (no trailing slash). Used for logout origin check.
APP_ORIGIN=http://localhost:3000

# SQLite file. In Docker mount a volume to this directory.
DB_PATH=./data/app.db

# Node port (adapter-node)
PORT=3000
HOST=0.0.0.0

# Sentry (self-hosted at sentry.rubeen.dev). DSN is safe to expose.
PUBLIC_SENTRY_DSN=
# Only needed at build time to upload source maps. Create at:
# https://sentry.rubeen.dev/settings/account/api/auth-tokens/  (scope: project:releases)
SENTRY_AUTH_TOKEN=
SENTRY_URL=https://sentry.rubeen.dev/
